{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user preferences and profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "plan": { "type": "string", "enum": ["Starter", "Pro", "Elite"], "description": "Subscription plan" },
        "preferredSession": { "type": "string", "enum": ["London", "New York", "All"], "description": "Preferred trading session" },
        "riskRewardThreshold": { "type": "number", "description": "Minimum R:R ratio" },
        "theme": { "type": "string", "enum": ["Light", "Dark"], "description": "UI theme preference" },
        "enableAiAlerts": { "type": "boolean", "description": "Enable AI trade setup notifications" },
        "enableMarketAlerts": { "type": "boolean", "description": "Enable significant market event notifications" },
        "isNewUser": { "type": "boolean", "description": "Flag for first-time welcome experience" },
        "status": { "type": "string", "enum": ["active", "banned"], "description": "User account status" },
        "lastReadNotificationsAt": { "type": "string", "format": "date-time", "description": "Last time user viewed notifications" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["email", "plan", "createdAt"]
    },
    "Trade": {
      "title": "Trade Analysis",
      "description": "Stores analyzed trade setups.",
      "type": "object",
      "properties": {
        "currency_pair": { "type": "string" },
        "timeframe": { "type": "string" },
        "current_price": { "type": "number" },
        "entry_price": { "type": "number" },
        "stop_loss": { "type": "number" },
        "take_profit": { "type": "number" },
        "score": { "type": "number" },
        "recommendation": { "type": "string" },
        "execution_signal": { "type": "string" },
        "confidence": { "type": "string" },
        "confidence_percentage": { "type": "number" },
        "score_details": {
          "type": "object",
          "properties": {
            "trend_score": { "type": "number" },
            "levels_score": { "type": "number" },
            "momentum_score": { "type": "number" },
            "entry_score": { "type": "number" },
            "rr_score": { "type": "number" }
          }
        },
        "trend": { "type": "string" },
        "volatility": { "type": "string" },
        "market_condition": { "type": "string" },
        "risk_reward": { "type": "string" },
        "execution_timing": { "type": "string" },
        "time_window": { "type": "string" },
        "expected_duration": { "type": "string" },
        "session": { "type": "string" },
        "reasoning": { "type": "string" },
        "current_price_estimate": { "type": "string" },
        "analysis_notes": { "type": "array", "items": { "type": "string" } },
        "trade_result": { "type": "string", "enum": ["Win", "Loss", "Break-even", "Pending"] },
        "analysis_type": { "type": "string" },
        "market_structure": { "type": "string" },
        "support_resistance": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["currency_pair", "score", "recommendation", "timestamp", "userId", "timeframe", "entry_price", "stop_loss", "take_profit"]
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "Stores a support conversation thread.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who opened the ticket" },
        "userEmail": { "type": "string", "description": "Email of the user" },
        "subject": { "type": "string", "description": "Subject of the ticket" },
        "status": { "type": "string", "enum": ["Open", "Pending", "Resolved"], "description": "Current status" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "createdAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a support ticket.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "ID of the sender" },
        "senderRole": { "type": "string", "enum": ["user", "admin"], "description": "Role of the sender" },
        "text": { "type": "string", "description": "Message content" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderRole", "text", "timestamp"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Records administrative actions.",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "adminEmail": { "type": "string" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["adminId", "action", "timestamp"]
    },
    "FeatureFlag": {
      "title": "Feature Flag",
      "description": "Controls availability of specific features.",
      "type": "object",
      "properties": {
        "feature_name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "description": { "type": "string" }
      },
      "required": ["feature_name", "enabled"]
    },
    "SystemConfig": {
      "title": "System Configuration",
      "description": "Global settings for the platform.",
      "type": "object",
      "properties": {
        "maintenanceMode": { "type": "boolean" },
        "broadcastMessage": { "type": "string" },
        "geminiModel": { "type": "string" }
      }
    },
    "Notification": {
      "title": "System Notification",
      "description": "Stores notifications sent to users.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Notification title" },
        "message": { "type": "string", "description": "Notification content" },
        "target": { "type": "string", "enum": ["All", "Basic", "Pro"], "description": "Target audience" },
        "type": { "type": "string", "enum": ["info", "warning", "success", "alert"], "description": "Type of notification" },
        "category": { "type": "string", "enum": ["ai_trade", "market_event", "system"], "description": "Notification category" },
        "createdAt": { "type": "string", "format": "date-time" },
        "adminId": { "type": "string", "description": "ID of the admin who sent it" }
      },
      "required": ["title", "message", "target", "createdAt", "adminId"]
    },
    "CommunityPost": {
      "title": "Community Post",
      "description": "A trade setup shared with the community.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "currency_pair": { "type": "string" },
        "entry": { "type": "number" },
        "stop_loss": { "type": "number" },
        "take_profit": { "type": "number" },
        "description": { "type": "string" },
        "result": { "type": "string", "enum": ["Win", "Loss", "Pending"], "description": "Outcome of the trade" },
        "likes": { "type": "number" },
        "dislikes": { "type": "number" },
        "commentCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "currency_pair", "entry", "stop_loss", "take_profit", "description", "createdAt"]
    },
    "CommunityComment": {
      "title": "Community Comment",
      "description": "A comment on a community post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "createdAt"]
    },
    "ForexCache": {
      "title": "Forex Rate Cache",
      "description": "Stores the latest fetched forex rates to stay within API quota.",
      "type": "object",
      "properties": {
        "currency_pair": { "type": "string" },
        "current_price": { "type": "number" },
        "high": { "type": "number" },
        "low": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "base": { "type": "string" },
        "quote": { "type": "string" }
      },
      "required": ["currency_pair", "current_price", "timestamp"]
    },
    "ArticleFeedback": {
      "title": "Article Feedback",
      "description": "Feedback on Knowledge Base articles.",
      "type": "object",
      "properties": {
        "articleId": { "type": "string" },
        "articleTitle": { "type": "string" },
        "helpful": { "type": "boolean" },
        "comment": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["articleId", "helpful", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "User's analyzed trades."
    },
    "/community_posts/{postId}": {
      "schema": "CommunityPost",
      "description": "Shared trade setups."
    },
    "/community_posts/{postId}/comments/{commentId}": {
      "schema": "CommunityComment",
      "description": "Comments on a post."
    },
    "/community_posts/{postId}/interactions/{userId}": {
      "schema": "object",
      "description": "Tracks likes/dislikes per user."
    },
    "/support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Support conversation threads."
    },
    "/support_tickets/{ticketId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a support ticket."
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Administrative audit logs."
    },
    "/admin_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Administrative audit logs (alias for audit_logs)."
    },
    "/feature_flags/{flagId}": {
      "schema": "FeatureFlag",
      "description": "Feature flag settings."
    },
    "/system_config/global": {
      "schema": "SystemConfig",
      "description": "Global platform settings."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System-wide notifications."
    },
    "/forex_cache/{pairId}": {
      "schema": "ForexCache",
      "description": "Global cache for forex rates."
    },
    "/article_feedback/{feedbackId}": {
      "schema": "ArticleFeedback",
      "description": "User feedback on Knowledge Base articles."
    }
  }
}
